#!/usr/bin/env python3
"""Terminal UI for Housing Command Center — works over SSH (Termux) or locally."""

from __future__ import annotations

import json
import os
import sys
import urllib.error
import urllib.request

BASE = os.environ.get("HCC_URL", "http://127.0.0.1:8787").rstrip("/")


def api(path: str, method: str = "GET", body: dict | None = None):
    data = None
    headers = {"Accept": "application/json"}
    if body is not None:
        data = json.dumps(body).encode()
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(f"{BASE}{path}", data=data, headers=headers, method=method)
    with urllib.request.urlopen(req, timeout=15) as resp:
        return json.load(resp)


def clear():
    os.system("clear" if os.name != "nt" else "cls")


def pause():
    input("\nPress Enter…")


def show_briefing():
    clear()
    try:
        payload = api("/api/briefing/today")
    except urllib.error.URLError as e:
        print(f"Cannot reach {BASE}\n{e}")
        print("\nTip: export HCC_URL=http://YOUR_PC_IP:8787")
        pause()
        return
    b = payload.get("briefing")
    if not b:
        print("No briefing today. Run: hcc daily")
        pause()
        return
    print("=" * 60)
    print(b.get("title", "Briefing"))
    print("=" * 60)
    print(b.get("summary", ""))
    urgent = payload.get("urgent") or []
    if urgent:
        print("\nURGENT:")
        for u in urgent:
            print(f"  ! {u}")
    tasks = payload.get("tasks") or []
    pending = [t for t in tasks if t.get("status") != "done"]
    print(f"\nTasks ({len(pending)} pending / {len(tasks)} total)\n")
    for i, t in enumerate(tasks, 1):
        mark = " " if t.get("status") == "done" else "○"
        print(f" {mark} {i}. [{t.get('estimated_minutes','?')}m] {t.get('title')}")
        if t.get("description"):
            print(f"      {t['description'][:90]}")
    pause()


def complete_task_menu():
    clear()
    try:
        payload = api("/api/briefing/today")
    except urllib.error.URLError as e:
        print(f"Offline: {e}")
        pause()
        return
    tasks = [t for t in payload.get("tasks", []) if t.get("status") != "done"]
    if not tasks:
        print("All tasks done!")
        pause()
        return
    for i, t in enumerate(tasks, 1):
        print(f" {i}. {t['title']}")
    print(" 0. Back")
    choice = input("\nMark done #: ").strip()
    if not choice.isdigit() or int(choice) == 0:
        return
    idx = int(choice) - 1
    if 0 <= idx < len(tasks):
        api(f"/api/tasks/{tasks[idx]['id']}/done", "POST", {"notes": ""})
        print("Done.")
        pause()


def outreach_menu():
    clear()
    try:
        payload = api("/api/outreach?status=draft")
    except urllib.error.URLError as e:
        print(f"Offline: {e}")
        pause()
        return
    items = payload.get("items") or []
    if not items:
        print("No draft outreach.")
        pause()
        return
    for i, it in enumerate(items, 1):
        print(f" {i}. {it.get('property_name')} — {it.get('subject')}")
    print(" 0. Back")
    choice = input("\nView/approve #: ").strip()
    if not choice.isdigit() or int(choice) == 0:
        return
    idx = int(choice) - 1
    if 0 <= idx < len(items):
        it = items[idx]
        clear()
        print(it.get("subject"))
        print("-" * 40)
        print((it.get("body") or "")[:2000])
        if input("\nApprove? [y/N] ").lower().startswith("y"):
            api(f"/api/outreach/{it['id']}/approve", "POST")
            print("Approved.")
        pause()


def main():
    while True:
        clear()
        print("HOUSING COMMAND CENTER (TUI)")
        print(f"Server: {BASE}\n")
        print(" 1. Today's briefing")
        print(" 2. Mark task done")
        print(" 3. Review outreach drafts")
        print(" 4. Health check")
        print(" 0. Quit")
        c = input("\nChoice: ").strip()
        if c == "1":
            show_briefing()
        elif c == "2":
            complete_task_menu()
        elif c == "3":
            outreach_menu()
        elif c == "4":
            try:
                h = api("/api/health")
                print(f"\nOK — {h}")
            except Exception as e:
                print(f"\nFail: {e}")
            pause()
        elif c == "0":
            break


if __name__ == "__main__":
    main()