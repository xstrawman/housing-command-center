# Copy to config.env and adjust for your GPU rental session.
# Source before running:  source gpu-day-kit/config.env

# ─── Paths ───────────────────────────────────────────────────────────────────
export HCC_ROOT="$HOME/housing-command-center"
export HCC_DB="$HCC_ROOT/db/housing.db"
export GPU_KIT="$HCC_ROOT/gpu-day-kit"
export GPU_EXPORTS="$GPU_KIT/exports"
export GPU_MODELS="$HOME/models"
export NOLLAMA_ROOT="$HOME/NoLlama"

# ─── Base model (Heretic input) ──────────────────────────────────────────────
export HERETIC_MODEL="Qwen/Qwen3-8B"
export HERETIC_OUTPUT="$GPU_MODELS/Qwen3-8B-heretic"
export HERETIC_QUANTIZATION=""          # set to bnb_4bit if VRAM tight

# ─── OpenVINO export (matches NoLlama layout) ────────────────────────────────
export OV_SOURCE="$HERETIC_OUTPUT"      # or path to merged HF weights
export OV_OUTPUT="$GPU_MODELS/Qwen3-8B-heretic-int4-cw-ov"
export OV_WEIGHT_FORMAT="int4"          # int4 | int8
export OV_DATASET="c4"                  # calibration dataset for NNCF

# ─── NoLlama deploy ──────────────────────────────────────────────────────────
export NOLLAMA_MODEL_LINK="$NOLLAMA_ROOT/model"
export NOLLAMA_PORT=11435

# ─── Inference endpoints for benchmark / batch gen ───────────────────────────
export HCC_LLM_URL="http://127.0.0.1:11435"   # NoLlama (NPU) or Ollama GPU
export HCC_LLM_MODEL="Qwen3-8B-int4-cw"
export HCC_GPU_LLM_URL="http://127.0.0.1:11434"  # Ollama on rented GPU
export HCC_GPU_LLM_MODEL="qwen3:8b"

# ─── Synthetic data targets ────────────────────────────────────────────────────
export SYNTH_EMAIL_REPLIES=2000
export SYNTH_OUTREACH_DRAFTS=218